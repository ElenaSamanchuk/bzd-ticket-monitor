# Скопируйте в config.env и заполните нужное.
# Без config.env работают только уведомления macOS + вывод в терминал.

# --- Telegram (рекомендуется) ---
# 1) напишите @BotFather → /newbot → получите токен
# 2) напишите боту любое сообщение
# 3) откройте https://api.telegram.org/bot<TOKEN>/getUpdates → найдите chat.id
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF
# TELEGRAM_CHAT_ID=987654321

# --- Email (опционально) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=app-password-from-google
# EMAIL_FROM=your@gmail.com
# EMAIL_TO=your@gmail.com
